        "Authorization": "Bearer YOUR_TOKEN_HERE"
      }
    },
    {
      "description": "Filtrar membros inativos",
      "method": "GET",
      "url": "/api/members?active=false&page=1&limit=15",
      "headers": {
        "Authorization": "Bearer YOUR_TOKEN_HERE"
      }
    },
    {
      "description": "Filtrar por cargo específico",
      "method": "GET",
