{
  "examples": [
    {
      "description": "Listar primeira página com 10 membros",
      "method": "GET",
      "url": "/api/members?page=1&limit=10",
      "headers": {
        "Authorization": "Bearer YOUR_TOKEN_HERE"
      }
    },
    {
      "description": "Buscar membros por nome",
      "method": "GET",
