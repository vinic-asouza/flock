        "Authorization": "Bearer YOUR_TOKEN_HERE"
      }
    },
    {
      "description": "Busca por email",
      "method": "GET",
      "url": "/api/members?search=@gmail.com&page=1&limit=10",
      "headers": {
        "Authorization": "Bearer YOUR_TOKEN_HERE"
      }
    },
    {
      "description": "Busca por telefone",
