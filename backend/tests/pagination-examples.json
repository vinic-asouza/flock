        "Authorization": "Bearer YOUR_TOKEN_HERE"
      }
    },
    {
      "description": "Combinação de filtros",
      "method": "GET",
      "url": "/api/members?search=Maria&active=true&role_id=123&congregation_id=456&page=2&limit=10",
      "headers": {
        "Authorization": "Bearer YOUR_TOKEN_HERE"
      }
    },
    {
      "description": "Segunda página com 5 membros",
      "method": "GET",
      "url": "/api/members?page=2&limit=5",
